{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"], 
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"] // <-- ESTO ES LO QUE SOLUCIONA EL ERROR DEL CONSOLE
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}